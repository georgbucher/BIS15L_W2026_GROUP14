ui <- page_fillable(
theme = bs_theme(
bg = "#e8f4f8",
fg = "#2c3e50",
primary = "#FF6B9D",
"navbar-bg" = "#4A90E2"
),
tags$head(
tags$style(HTML("
body {
background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
background-attachment: fixed;
}
.card {
background: rgba(255, 255, 255, 0.95) !important;
